# Copy this to .env and fill in your values

# n8n instance URL (default works for local install)
N8N_BASE_URL=http://localhost:5678

# API key — create one at: n8n Settings > n8n API > Create API key
N8N_API_KEY=your_api_key_here

# Refresh interval in seconds (default: 3)
N8N_POLL_INTERVAL=3.0

# Max executions shown in table (default: 50)
N8N_MAX_EXECUTIONS=50
